<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    <meta name="facebook-domain-verification" content="nu2wnbkm11f05dwik0vlrvggdheb47" />

    {%- if request.path == '/collections' -%}
      <meta name="robots" content="noindex, follow">
    {%- elsif template == 'collection' and collection.handle == 'all' -%}
      <meta name="robots" content="noindex, follow">
    {%- endif -%}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} | {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {%- comment -%}LLM-readable site information for AI tools{%- endcomment -%}
    <link rel="alternate" type="text/plain" href="{{ shop.url }}/pages/llms" title="LLM-readable site information">

    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'app.js' | asset_url }}" defer="defer"></script>
  
    {{ content_for_header }}
   
    {% comment %} 
      {{ 'Sysum-Medium.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }}
      {{ 'Universal-Sans-Display-400.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2' }} 
    {% endcomment %}
      
    {{ 'app.css' | asset_url | stylesheet_tag }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
  </head>

  <body
    id="{{ template.name | split: '.' | first }}"
    x-data="setData"
    @resize.window="isMobile = (window.innerWidth < 768) ? true : false"
    :class="{ '!overflow-hidden' : showDrawer || showMenu || showFilters || zoomView || lockScroll, 'blackout' : blackout }"
    @keydown.escape.window="drawerTab='', showDrawer=false, showNav=false, showMenu=false, showFilters=false"
    @lock-screen.window="lockScroll=$event.detail" {% comment %}  Used in addresses {% endcomment %}
    x-cloak
    >

    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}        
      gtag('config', 'G-8GMNN2MMMC', {
        'content_group': '{{ template }}'
      });
    </script>
    
    <a class="skip-to-content-link p-1 rounded text-12 leading-none bg-white absolute -top-20 focus:top-2 md:focus:top-3 left-1/2 -translate-x-1/2 z-[200]" href="#MainContent">{{ "accessibility.skip_to_text" | t }}</a>

    {% section 'header' %}

    <main id="MainContent" role="main" tabindex="-1">
      {% if request.path == '/account/subscribe' %}
        {% section 'subscribe-confirmation' %}
      {% else %}
        {{ content_for_layout }}
      {% endif %}
    </main>

    {% section 'footer' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <div class="page-loader flex flex-col gap-3 fixed justify-center items-center inset-0 bg-sand z-[1000] transition-opacity duration-320 ease-sysum">
      <svg class="h-6 fill-pebble animate-pulse" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 19 30"><title>Sysum loading</title>{% render 'icons' with 'buttercup' %}</svg>
      <noscript><div class="text-16">This website requires JavaScript to work</div></noscript>
    </div>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        preOrder: `{{ 'products.product.pre_order' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
        unavailable_with_option: `{{ 'products.product.value_unavailable' | t: option_value: '[value]' }}`,
      };

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.success_message' | t }}`,
        pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
        playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`,
        recipientFormExpanded: `{{ 'recipient.form.expanded' | t }}`,
        recipientFormCollapsed: `{{ 'recipient.form.collapsed' | t }}`,
      };
    </script>

    <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>

    {% render 'info-drawer' %}
    {% render 'cookie-banner' %}
    {%- unless customer and customer.accepts_marketing -%}
      {% render 'sign-up' %}
    {%- endunless -%}
    
  </body>
</html>
