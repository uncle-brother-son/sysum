<section id="MainProduct-{{ section.id }}" class="page-width section-{{ section.id }}-padding" data-section="{{ section.id }}" 
  x-data="product({ slideCount: {{ product.media.size }} })"
  x-init="productInit()"
  x-ref="product"
>

  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}

  <div class="grid_ mb-1 bg-sand-wet rounded" x-intersect="$el.classList.add('scrollin', 'ease-sysum')">
    
    <div class="w-full col-span-full md:col-span-7 col-start-1">
      {% render 'product-media-gallery', variant_images: variant_images %}
    </div>

    <div class="w-full px-2 md:px-0 pt-3 pb-5 md:pb-0 md:flex col-span-full md:col-span-3 col-start-1 md:col-start-9">

      <product-info 
        id="ProductInfo-{{ section.id }}" 
        data-section="{{ section.id }}" 
        data-url="{{ product.url }}"
        class="w-full md:sticky md:bottom-10 md:mb-10 md:self-end"
        {% for option in product.options_with_values %}
          {% if option.name == "Size" %}
            {% if option.values.size == 1 %}
              x-data="{ checked : true }"
            {% else %}
              x-data="{ checked : false }"
            {% endif %} 
          {% endif %}
        {% endfor %}
      > 
      
        {%- assign product_form_id = 'product-form-' | append: section.id -%}
        {%- assign product_form_float_id = 'product-form-float-' | append: section.id -%}

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'title' -%}
              <div id="CTA" class="product__title mb-1" {{ block.shopify_attributes }}>
                <h1 class="h1">{{ product.title | escape }}</h1>
              </div>
            {%- when 'price' -%}
              <div class="mb-2 no-js-hidden" id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                {%- render 'price', product: product, use_variant: false, show_badges: false, price_class: 'h1' -%}
              </div>
              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                {%- endform -%}
              </div>
            {%- when 'text' -%}
              <div class="product__text text-12" {{ block.shopify_attributes }}>{{- block.settings.text -}}</div>
              <a class="inline-block a text-12 mt-0 mb-3 hover:cursor-s-resize" href="#product-description" @click.prevent="prodFeature = 1, pageScroll('productDescription')">{{ 'products.product.view_full_details' | t }}</a>
            {%- when 'variant_picker' -%}
              {% comment %} {% render 'product-gender-toggle' %} {% endcomment %}
              {% render 'product-swatches' %}
              {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
            {%- when 'inventory' -%}
              <div class="flex justify-between w-full mt-1 mb-3">
                <div class="text-12" {{ block.shopify_attributes }} id="Inventory-{{ section.id }}" role="status">
                  <span x-show="!checked">Please select a size</span>
                  <span x-show="checked">
                  {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                    {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      {%- if product.metafields.custom.preorder -%}
                        <span class="text-moss_l">{{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}{{ product.metafields.custom.preorder }}</span>
                      {%- else -%}
                        {%- if product.selected_or_first_available_variant.inventory_quantity <= block.settings.inventory_threshold -%}
                          <span class="text-sap">{{- 'products.product.inventory_low_stock' | t -}}</span>
                        {%- else -%}                       
                          <span class="text-moss_l">{{- 'products.product.inventory_in_stock' | t -}}</span>
                        {%- endif -%}
                      {%- endif -%}
                    {%- else -%}
                      {%- if product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
                        <span class="text-moss_l">{{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}{{ product.metafields.custom.preorder }}</span>
                      {%- else -%}
                        <span class="text-clay">{{- 'products.product.inventory_out_of_stock' | t -}}</span>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                  </span>
                </div>
                <a class="a text-12 hover:cursor-s-resize" href="#" @click.prevent="prodFeature = 5, pageScroll('productSizeFit')">Size & Fit</a>
              </div>
            {%- when 'buy_buttons' -%}
              {%- render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true -%}
            {%- when 'icon-with-text' -%}
              {% render 'icon-with-text', block: block %}
          {%- endcase -%}
        {%- endfor -%}
      </product-info>
    </div>

  </div>

  <div class="px-1 md:px-4 flex gap-1" x-intersect="$el.classList.add('scrollin', 'ease-sysum')">
    {%- render 'product-detail-images', variant_images: variant_images -%}
  </div>

  {%- render 'product-info' -%}
  {%- render 'product-gallery-feature' -%}
  {%- render 'product-gallery-shop' -%}
  {%- render 'product-media-modal' variant_images: variant_images -%}

  <div x-show="showCTA" class="fixed w-auto md:w-CD3 lg:w-CD2 bottom-0 pb-1 md:pb-3 left-2 md:left-auto right-2 md:right-5 z-20" x-transition:enter="transition duration-640 ease-sysum" x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0" x-transition:leave="transition duration-320 ease-sysum" x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"> 
    <div class="p-1 rounded bg-sand-wet/60 backdrop-blur-sm flex gap-1">
      <div class="flex-none w-4">
        {{ product.media[1] | image_url: width: 128 | image_tag: loading: 'lazy', width: product.media[0].width, height: product.media[0].height, sizes: '32px', widths: '256, 720, 1024, 1260, 1450' }}
      </div>
      {%- render 'buy-button-float', product: product, product_form_id: product_form_float_id, section_id: section.id, show_pickup_availability: true -%}
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      function isIE() {
        const ua = window.navigator.userAgent;
        const msie = ua.indexOf('MSIE ');
        const trident = ua.indexOf('Trident/');

        return msie > 0 || trident > 0;
      }

      if (!isIE()) return;
      const hiddenInput = document.querySelector('#{{ product_form_id }} input[name="id"]');
      const noScriptInputWrapper = document.createElement('div');
      const variantSwitcher =
        document.querySelector('variant-radios[data-section="{{ section.id }}"]') ||
        document.querySelector('variant-selects[data-section="{{ section.id }}"]');
      noScriptInputWrapper.innerHTML = document.querySelector(
        '.product-form__noscript-wrapper-{{ section.id }}'
      ).textContent;
      variantSwitcher.outerHTML = noScriptInputWrapper.outerHTML;

      document.querySelector('#Variants-{{ section.id }}').addEventListener('change', function (event) {
        hiddenInput.value = event.currentTarget.value;
      });
    });
  </script>

  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".speakable-product-description", ".speakable-product-features", ".speakable-functional-features"]
      },
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      {%- comment -%} Enhanced: Material from composition metafield (extract actual fabric) {%- endcomment -%}
      {%- if product.metafields.custom.info.value.composition.value -%}
        {%- assign first_comp = product.metafields.custom.info.value.composition.value | first | split: '|' -%}
        {%- if first_comp.size > 1 -%}
          {%- assign comp_value = first_comp[1] | split: '%' -%}
          {%- if comp_value.size > 1 -%}
            {%- assign fabric_name = comp_value[1] | split: '/' | first | strip -%}
            "material": {{ fabric_name | json }},
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}
      {%- comment -%} Enhanced: Category mapping {%- endcomment -%}
      {%- if product.type != blank -%}
        "category": "Sporting Goods > Outdoor Recreation > Trail Running > {{ product.type }}",
      {%- endif -%}
      {%- comment -%} Enhanced: Audience from tags {%- endcomment -%}
      {%- assign gender = '' -%}
      {%- if product.tags contains 'Men' -%}
        {%- assign gender = 'male' -%}
      {%- elsif product.tags contains 'Women' -%}
        {%- assign gender = 'female' -%}
      {%- elsif product.tags contains 'Unisex' -%}
        {%- assign gender = 'unisex' -%}
      {%- endif -%}
      {%- if gender != '' -%}
        "audience": {
          "@type": "PeopleAudience",
          "suggestedGender": {{ gender | json }},
          "suggestedMinAge": 18
        },
      {%- endif -%}
      {%- comment -%} Enhanced: Additional properties - dynamically pulled from metafields {%- endcomment -%}
      "additionalProperty": [
        {%- comment -%} Features from metafields {%- endcomment -%}
        {%- if product.metafields.custom.info.value.features.value -%}
          {%- for feature in product.metafields.custom.info.value.features.value -%}
            {
              "@type": "PropertyValue",
              "name": "Feature",
              "value": {{ feature | json }}
            },
          {%- endfor -%}
        {%- endif -%}
        {%- comment -%} Functional features from feature gallery metafield {%- endcomment -%}
        {%- if product.metafields.custom.feature_gallery.value -%}
          {%- for functional_feature in product.metafields.custom.feature_gallery.value -%}
            {%- if functional_feature.description -%}
              {
                "@type": "PropertyValue",
                "name": "Functional Feature",
                "value": {{ functional_feature.description.value | json }}
              },
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- comment -%} Composition breakdown from metafields {%- endcomment -%}
        {%- if product.metafields.custom.info.value.composition.value -%}
          {%- for composition in product.metafields.custom.info.value.composition.value -%}
            {%- assign comp_parts = composition | split: '|' -%}
            {
              "@type": "PropertyValue",
              "name": {{ comp_parts[0] | json }},
              "value": {{ comp_parts[1] | json }}
            },
          {%- endfor -%}
        {%- endif -%}
        {%- comment -%} Weight from metafields {%- endcomment -%}
        {%- if product.metafields.custom.info.value.weight -%}
          {
            "@type": "PropertyValue",
            "name": "Weight",
            "value": {{ product.metafields.custom.info.value.weight | json }}
          },
        {%- endif -%}
        {%- comment -%} Production location from metafields {%- endcomment -%}
        {%- if product.metafields.custom.info.value.production -%}
          {
            "@type": "PropertyValue",
            "name": "Production Location",
            "value": {{ product.metafields.custom.info.value.production | json }}
          },
        {%- endif -%}
        {%- comment -%} Responsibility from metafields (product-specific sustainability) {%- endcomment -%}
        {%- if product.metafields.custom.info.value.responsibility.value -%}
          {%- for responsibility in product.metafields.custom.info.value.responsibility.value -%}
            {%- assign resp_parts = responsibility | split: '|' -%}
            {
              "@type": "PropertyValue",
              "name": "Sustainability: {{ resp_parts[0] }}",
              "value": {{ resp_parts[1] | json }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        {%- endif -%}
      ],
      {%- comment -%} Future: Aggregate rating (uncomment when Junip reviews are live)
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "24"
      },
      {%- endcomment -%}
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }},
            {%- comment -%} UK Delivery - Parse from metaobjects {%- endcomment -%}
            {%- if shop.metaobjects.delivery.standard-uk -%}
              {%- assign uk_cost_row = shop.metaobjects.delivery.standard-uk.cost.value | first | split: '|' -%}
              {%- assign uk_cost_value = uk_cost_row[1] | downcase -%}
              {%- assign uk_duration_row = shop.metaobjects.delivery.standard-uk.duration.value | first | split: '|' -%}
              {%- assign uk_duration_range = uk_duration_row[1] | split: ' ' | first | split: '-' -%}
              "shippingDetails": {
                "@type": "OfferShippingDetails",
                "shippingRate": {
                  "@type": "MonetaryAmount",
                  "value": {% if uk_cost_value contains 'free' %}"0"{% else %}{{ uk_cost_row[1] | remove: '£' | strip | json }}{% endif %},
                  "currency": "GBP"
                },
                "shippingDestination": {
                  "@type": "DefinedRegion",
                  "addressCountry": "GB"
                },
                "deliveryTime": {
                  "@type": "ShippingDeliveryTime",
                  "handlingTime": {
                    "@type": "QuantitativeValue",
                    "minValue": 0,
                    "maxValue": 1,
                    "unitCode": "DAY"
                  }
                  {%- if uk_duration_range.size == 2 -%}
                    ,"transitTime": {
                      "@type": "QuantitativeValue",
                      "minValue": {{ uk_duration_range[0] }},
                      "maxValue": {{ uk_duration_range[1] }},
                      "unitCode": "DAY"
                    }
                  {%- endif -%}
                }
              },
            {%- endif -%}
            "hasMerchantReturnPolicy": {
              "@type": "MerchantReturnPolicy",
              "applicableCountry": "GB",
              "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
              "merchantReturnDays": 14,
              "returnMethod": "https://schema.org/ReturnByMail",
              "returnFees": "https://schema.org/FreeReturn"
            }
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ request.origin | json }}
        }
        {%- liquid
          if product.metafields.custom.primary_collection != blank
            assign breadcrumb_collection = product.metafields.custom.primary_collection.value
          elsif product.collections.size > 0
            assign breadcrumb_collection = product.collections.first
          else
            assign breadcrumb_collection = null
          endif
        -%}
        {%- if breadcrumb_collection -%}
          {%- liquid
            assign dept = breadcrumb_collection.title | split: "'" | first
            assign category = breadcrumb_collection.title | split: " " | last
          -%}
          {%- if category != "Clothing" and dept == 'Women' or dept == 'Men' -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": "{{ dept }}'s Clothing",
              "item": "{{ request.origin }}/collections/{{ dept | downcase | append: 's' }}-running-clothing"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": {{ breadcrumb_collection.title | replace: "Men's ", "" | replace: "Women's ", "" | json }},
              "item": {{ request.origin | append: breadcrumb_collection.url | json }}
            }
          {%- else -%}
            ,{
              "@type": "ListItem",
              "position": 2,
              "name": {{ breadcrumb_collection.title | json }},
              "item": {{ request.origin | append: breadcrumb_collection.url | json }}
            }
          {%- endif -%}
        {%- endif -%}
        ,{
          "@type": "ListItem",
          "position": {% if breadcrumb_collection %}{% if category != "Clothing" and dept == 'Women' or dept == 'Men' %}4{% else %}3{% endif %}{% else %}2{% endif %},
          "name": {{ product.title | json }}
        }
      ]
    }
  </script>
</section>

{% schema %}
{
  "name": "t:sections.main-product.name",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "text",
      "name": "t:sections.main-product.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Text block",
          "label": "t:sections.main-product.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.main-product.blocks.title.name",
      "limit": 1
    },
    {
      "type": "price",
      "name": "t:sections.main-product.blocks.price.name",
      "limit": 1
    },
    {
      "type": "inventory",
      "name": "t:sections.main-product.blocks.inventory.name",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "inventory_threshold",
          "label": "t:sections.main-product.blocks.inventory.settings.inventory_threshold.label",
          "min": 0,
          "max": 10,
          "step": 1,
          "info": "t:sections.main-product.blocks.inventory.settings.inventory_threshold.info",
          "default": 3
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "t:sections.main-product.blocks.variant_picker.name",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "t:sections.main-product.blocks.buy_buttons.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.label",
          "info": "t:sections.main-product.blocks.buy_buttons.settings.show_dynamic_checkout.info"
        }
      ]
    },
    {
      "type": "description",
      "name": "t:sections.main-product.blocks.description.name",
      "limit": 1
    },
    {
      "type": "icon-with-text",
      "name": "t:sections.main-product.blocks.icon_with_text.name",
      "settings": [
        {
          "type": "header",
          "content": "t:sections.main-product.blocks.icon_with_text.settings.content.label",
          "info": "t:sections.main-product.blocks.icon_with_text.settings.content.info"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            {
              "value": "none",
              "label": "t:sections.main-product.blocks.collapsible_tab.settings.icon.options__1.label"
            },
            {
              "value": "shipping",
              "label": "t:sections.main-product.blocks.collapsible_tab.settings.icon.options__2.label"
            },
            {
              "value": "returns",
              "label": "t:sections.main-product.blocks.collapsible_tab.settings.icon.options__3.label"
            },
            {
              "value": "global",
              "label": "t:sections.main-product.blocks.collapsible_tab.settings.icon.options__4.label"
            },
            {
              "value": "email",
              "label": "t:sections.main-product.blocks.collapsible_tab.settings.icon.options__5.label"
            }
          ],
          "default": "none",
          "label": "t:sections.main-product.blocks.icon_with_text.settings.icon.label"
        },
        {
          "type": "text",
          "id": "uk",
          "label": "UK Message"
        },
        {
          "type": "text",
          "id": "europe",
          "label": "Europe Message"
        },
        {
          "type": "text",
          "id": "worldwide",
          "label": "Worldwide Message"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "care",
      "label": "Care info"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "default": true,
      "label": "t:sections.main-product.settings.enable_video_looping.label"
    }
  ]
}
{% endschema %}