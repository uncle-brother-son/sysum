
{%- liquid
  assign image_height = section.settings.image_1.width | divided_by: section.settings.image_1.aspect_ratio
  assign sizes = '(min-width: 780px) calc(50vw - 44px), calc(100vw - 16px)'
-%}

<div class="grid_ mb-1 gap-y-1">
  <div class="relative col-span-full md:col-start-1 md:col-span-6" x-intersect="$el.classList.add('scrollin', 'ease-sysum')">
    {% if section.settings.video_1 %}
      {{ section.settings.video_1 | video_tag: image_size: '1100x', autoplay: true, loop: true, controls: false, muted: true }}
    {% else %}
      {{ section.settings.image_1 | image_url: width: 2048 | image_tag: loading: 'eager', width: section.settings.image_1.width, height: image_height, sizes: sizes, widths: '285, 750, 1024, 1236, 1460, 1630, 1780, 1920, 2048' }}
    {% endif %}
    <a href="{{ section.settings.link_1 }}" class="group absolute inset-0 justify-center flex w-full py-8 md:py-12">
      <span class="primary_s sticky bottom-8 self-end group-hover:bg-sand/90">
        {{ section.settings.text_1 }}
      </span>
    </a>
  </div>
  <div class="relative col-span-full md:col-start-7 md:col-span-6" x-intersect="$el.classList.add('scrollin', 'ease-sysum')">
    {% if section.settings.video_2 %}
      {{ section.settings.video_2 | video_tag: image_size: '1100x', autoplay: true, loop: true, controls: false, muted: true }}
    {% else %}
      {{ section.settings.image_2 | image_url: width: 2048 | image_tag: loading: 'eager', width: section.settings.image_1.width, height: image_height, sizes: sizes, widths: '285, 750, 1024, 1236, 1460, 1630, 1780, 1920, 2048' }}
    {% endif %}
    <a href="{{ section.settings.link_2 }}" class="group absolute inset-0 justify-center flex w-full py-8 md:py-12">
      <span class="primary_s sticky bottom-8 self-end group-hover:bg-sand/90">
        {{ section.settings.text_2 }}
      </span>
    </a>
  </div>
</div>


{% schema %}
{
  "name": "Image split",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Left image"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "Left video"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Left text"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "Left link"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Right image"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "Right video"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Right text"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Right link"
    }
  ],
  "presets": [
    {
      "name": "Image split"
    }
  ]
}
{% endschema %}