<div class="template-404 grid_ pt-2 md:pt-3 mb-4 md:mb-6" x-intersect="$el.classList.add('scrollfadein', 'ease-sysum')">
  <div class="col-span-full mb-4 md:mb-0 px-1 flex flex-col gap-6">
    <h1>{{ 'templates.404.title' | t }}</h1>
    <div>
      <p>{{ 'templates.404.subtext' | t }}</p>
      <a href="{{ section.settings.link }}" class="primary">{{ 'templates.404.link' | t }}</a>
    </div>
    <div class="relative" x-intersect="$el.classList.add('scrollin', 'ease-sysum')">
      {% if section.settings.video %}
        {{ section.settings.video | video_tag: image_size: '1100x', autoplay: true, loop: true, controls: false, muted: true }}
      {% else %}
        <picture id="flip">
          <source media="(max-width: 767px)" srcset="{{ section.settings.image_2 | image_url: width: 488 }} 488w, {{ section.settings.image_2 | image_url: width: 767 }} 767w " sizes="(min-width: 780px) calc(100vw - 80px), calc(100vw - 16px)">
          {{ section.settings.image | image_url: width: 2480 | image_tag: loading: 'eager', widths: '720, 1100, 1376, 1630, 1850, 2048', sizes: '(min-width: 780px) calc(100vw - 80px), calc(100vw - 16px)' }}
        </picture>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-404.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.main-404.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:sections.main-404.settings.image_2.label"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Main 404"
    }
  ]
}
{% endschema %}