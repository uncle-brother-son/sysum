<div class="customer reset-password grid_ pt-2 md:pt-3 pb-8 md:pb-10">
  <h1 class="mb-6 col-span-full md:col-start-1 md:col-span-10 mx-1 md:mr-0" x-intersect="$el.classList.add('scrollfadein', 'ease-sysum')">
    {{ 'customer.reset_password.title' | t }}
  </h1>
  {%- form 'reset_customer_password', class: 'col-span-full md:col-start-1 md:col-span-5 xl:col-start-1 xl:col-span-4 mx-1 md:mr-0' -%}
    <div x-intersect="$el.classList.add('scrollfadein', 'ease-sysum')">

      {%- if form.errors -%}
        <p class="form__message flex items-center gap-x-1 error" tabindex="-1" autofocus>
          <span class="visually_hidden">{{ 'accessibility.error' | t }} </span>
          <svg class="icon-error !fill-clay" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><title>Error</title>{% render 'icons' with 'icon-error' %}</svg>
          {{ 'templates.contact.form.error_heading' | t }}
        </p>
        <ul class="style-dash mb-5 ml-3">
          {%- for field in form.errors -%}
            <li>
              {%- if field == 'form' -%}
                {{ form.errors.messages[field] }}
              {%- else -%}
                <a href="#{{ field }}" class="text-link text-12">
                  {{ form.errors.translated_fields[field] | capitalize }}
                  {{ form.errors.messages[field] }}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p>
          {{ 'customer.reset_password.subtext' | t }}
        </p>
      {%- endif -%}


      <div class="field" x-data="{ showPassword: true, passwordValue: '' }">
        <div class="flex flex-row">
          <input
            type="password"
            value=""
            name="customer[password]"
            id="password"
            autocomplete="new-password"
            {% if form.errors contains 'password' %}
              aria-invalid="true"
              aria-describedby="password-error"
            {% endif %}
            placeholder=" "
            class="{%- if form.errors contains 'password' -%}error{%- endif -%}"
            :type="showPassword ? 'password' : 'text'"
            x-model="passwordValue"
          >
          <label for="password">{{ 'customer.reset_password.password' | t }} ({{ 'customer.reset_password.password_placeholder' | t }})</label>
          <div class="p-2.5 bg-white cursor-pointer tabfocus" :class="passwordValue.length > 0 ? 'block' : 'hidden'"  @click="showPassword = !showPassword" tabindex="0">
            <svg x-show="showPassword" class="icon-eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><title>Show password</title>{% render 'icons' with 'icon-eye-closed' %}</svg>
            <svg x-show="!showPassword" class="icon-eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><title>Hide password</title>{% render 'icons' with 'icon-eye-open' %}</svg>
          </div>
        </div>
        {%- if form.errors contains 'password' -%}
          <span id="password-error" class="form__message">
            {{ form.errors.translated_fields.password | capitalize }}
            {{ form.errors.messages.password }}
          </span>
        {%- endif -%}
      </div>

      <div class="field" x-data="{ showPassword: true, passwordValue: '' }">
        <div class="flex flex-row">
          <input
            type="password"
            value=""
            name="customer[password_confirmation]"
            id="password_confirmation"
            autocomplete="new-password"
            {% if form.errors contains 'password_confirmation' %}
              aria-invalid="true"
              aria-describedby="password_confirmation-error"
            {% endif %}
            placeholder=" "
            class="{%- if form.errors contains 'password' -%}error{%- endif -%}"
            :type="showPassword ? 'password' : 'text'"
            x-model="passwordValue"
          >
          <label for="password_confirmation">{{ 'customer.reset_password.password_confirm' | t }}</label>
          <div class="p-2.5 bg-white cursor-pointer tabfocus" :class="passwordValue.length > 0 ? 'block' : 'hidden'"  @click="showPassword = !showPassword" tabindex="0">
            <svg x-show="showPassword" class="icon-eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><title>Show password</title>{% render 'icons' with 'icon-eye-closed' %}</svg>
            <svg x-show="!showPassword" class="icon-eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><title>Hide password</title>{% render 'icons' with 'icon-eye-open' %}</svg>
          </div>
        </div>
        {%- if form.errors contains 'password_confirmation' -%}
          <span id="password_confirmation-error" class="form__message">
            {{ form.errors.translated_fields.password_confirmation | capitalize }}
            {{ form.errors.messages.password_confirmation }}
          </span>
        {%- endif -%}
      </div>

      <div class="flex w-full mt-3">
        <button class="primary">
          {{ 'customer.reset_password.submit' | t }}
        </button>
      </div>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "t:sections.main-reset-password.name",
  "settings": [

  ]
}
{% endschema %}
