<div class="relative mx-1 md:mx-4 mb-1" x-intersect="$el.classList.add('scrollin', 'ease-sysum')">
  {% if section.settings.video %}
    {{ section.settings.video | video_tag: image_size: '1100x', autoplay: true, loop: true, controls: false, muted: true }}
  {% else %}
    <picture id="flip">
      <source media="(max-width: 767px)" srcset="{{ section.settings.image_2 | image_url: width: 488 }} 488w, {{ section.settings.image_2 | image_url: width: 767 }} 767w " sizes="(min-width: 780px) calc(100vw - 80px), calc(100vw - 16px)">
      {{ section.settings.image | image_url: width: 2480 | image_tag: loading: 'eager', widths: '720, 1100, 1376, 1630, 1850, 2048', sizes: '(min-width: 780px) calc(100vw - 80px), calc(100vw - 16px)' }}
    </picture>
  {% endif %}
  <a href="{{ section.settings.link }}" class="group absolute inset-0 justify-center flex w-full py-8 md:py-12">
    <span class="primary_s sticky bottom-8 self-end group-hover:bg-sand/90">
      {{ section.settings.text }}
    </span>
  </a>
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-banner.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "t:sections.image-banner.settings.image_2.label"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}