<div class="grid_ mb-20 md:mb-25">
  {% render 'sticky-nav' %}
  <div class="flex flex-col gap-10 col-span-full md:col-start-4 md:col-span-7 mx-1 md:mx-0 md:pt-3" x-intersect="$el.classList.add('scrollfadein', 'ease-sysum')">
      
      {% assign legal_content = page.content %}
      {% assign legal_content_length = legal_content | split: ' ' %}

      <h1>{{ page.title | escape }}</h1>
      {% if page.title == 'Manage cookies' %}
        <p><button class="primary" @click="$dispatch('manage-cookies')">Change your consent</button></p>
      {% endif %}
      {% if legal_content_length.size > 1 %}
        {{ page.content }}
      {% else %}
        {{ shop[legal_content].body }}
      {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.legal-page.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Legal Menu Name"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Legal Menu"
    }
  ]
}
{% endschema %}
